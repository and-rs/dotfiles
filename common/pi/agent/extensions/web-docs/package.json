{
  "name": "pi-web-docs-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit --target ES2022 --module ESNext --moduleResolution Bundler --skipLibCheck --allowImportingTsExtensions index.ts"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@earendil-works/pi-tui": "^0.74.0",
    "@mozilla/readability": "^0.6.0",
    "exa-js": "^1.9.1",
    "jsdom": "^26.1.0",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2",
    "typebox": "^1.0.55"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.10.0",
    "@types/turndown": "^5.0.5",
    "typescript": "^5.9.3"
  }
}
