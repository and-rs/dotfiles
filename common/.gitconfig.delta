[delta "general"]
    minus-style                   = red
    minus-non-emph-style          = red
    minus-empty-line-marker-style = red
    minus-emph-style              = red bold strike
    line-numbers-minus-style      = red bold

    plus-style                    = cyan
    plus-non-emph-style           = cyan
    plus-empty-line-marker-style  = cyan
    plus-emph-style               = cyan bold strike
    line-numbers-plus-style       = cyan bold

    whitespace-error-style        = reverse
    hunk-header-decoration-style  = blue box
    hunk-header-style             = line-number white
    line-numbers-zero-style       = white
    zero-style                    = white
