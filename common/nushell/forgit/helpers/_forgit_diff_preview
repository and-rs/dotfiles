#!/usr/bin/env nu

export def main [
  file: string # Target file
  --staged (-s) # Show staged diff
] {
  let clean_file = ($file | ansi strip | str trim)
  if ($clean_file | is-empty) { return }

  let root = (git rev-parse --show-toplevel | str trim)
  let target = ($root | path join $clean_file)
  let status = (git -C $root status --porcelain -u -- $clean_file | lines | get 0? | default "")
  let has_delta = (which delta | is-not-empty)
  let diff_args = if $staged { ["--staged"] } else { [] }

  with-env {GIT_PAGER_IN_USE: "true"} {
    if (not $staged) and ($status | str starts-with '??') and ($target | path exists) {
      git -C $root diff --no-index -- /dev/null $target | if $has_delta { delta --paging=never } else { cat }
    } else {
      git -C $root diff ...$diff_args -- $clean_file | if $has_delta { delta --paging=never } else { cat }
    }
  }
}

