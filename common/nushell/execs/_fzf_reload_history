#!/usr/bin/env -S nu --config ~/.config/nushell/config.nu

export def main [] {
    open $nu.history-path
    | query db "SELECT command_line, MAX(start_timestamp) AS latest_start FROM history GROUP BY command_line ORDER BY latest_start DESC"
    | each { |it| $"( $it.command_line )\t( $it.latest_start )" }
    | str join (char -i 0)
}
