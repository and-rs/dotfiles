[init]
	defaultBranch = "main"

[core]
  pager = delta
  editor = bob run 0.12.1

[interactive]
  diffFilter = delta --color-only

[include]
    path = ~/.gitconfig.delta

[delta]
  features = neovim-default
  max-line-length = 0
  line-numbers = true
  navigate = true

[merge]
  conflictstyle = diff3
	tool = vscode-diff

[mergetool "vscode-diff"]
	cmd = bob run 0.12.1 \"$MERGED\" -c \"CodeDiff merge \\\"$MERGED\\\"\"

[user]
  name = "and-rs"
  email = "deserd@protonmail.com"

[credential "https://github.com"]
	useHttpPath = true
	helper = 
	helper = !/nix/store/y3m73nv1ry783kqfjqq17p3kxxaxx5d1-gh-2.92.0/bin/.gh-wrapped auth git-credential

[credential "https://gist.github.com"]
	helper = 
	helper = !/nix/store/y3m73nv1ry783kqfjqq17p3kxxaxx5d1-gh-2.92.0/bin/.gh-wrapped auth git-credential

[credential "https://gitlab.com"]
	helper =
	helper = !/run/current-system/sw/bin/glab auth git-credential
